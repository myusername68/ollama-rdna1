#!/usr/bin/env bash
# ollama-rdna1: drop-in replacement for ollama using llama.cpp + Vulkan
# Provides: serve, run, list, pull, stop, ps

set -euo pipefail

SHIM_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LLAMA_DIR="$SHIM_DIR/llama.cpp"
LLAMA_SERVER="$LLAMA_DIR/build/bin/llama-server"
LLAMA_CLI="$LLAMA_DIR/build/bin/llama-cli"
LLAMA_MTMD_CLI="$LLAMA_DIR/build/bin/llama-mtmd-cli"
OLLAMA_PROXY="$SHIM_DIR/ollama_proxy.py"
MODELS_DIR="$SHIM_DIR/models"
PORT=11434
BACKEND_PORT=8081
GPU_LAYERS=99
PID_FILE="/tmp/ollama-rdna1.pid"
PROXY_PID_FILE="/tmp/ollama-rdna1-proxy.pid"
LOG_FILE="/tmp/ollama-rdna1.log"

# --- model registry ---
OLLAMA_REGISTRY="https://registry.ollama.ai"

# Local cache of pulled models: maps "name:tag" -> gguf filename
MANIFEST_DIR="$MODELS_DIR/.manifests"

# --- helpers ---

red()    { echo -e "\033[31m$*\033[0m"; }
green()  { echo -e "\033[32m$*\033[0m"; }
yellow() { echo -e "\033[33m$*\033[0m"; }

parse_model_ref() {
    # Parse "qwen2.5" or "qwen2.5:7b" or "library/qwen2.5:7b"
    local ref="$1"
    local library="library"
    local model tag

    # strip leading library/ if present
    ref="${ref#library/}"

    if [[ "$ref" == *":"* ]]; then
        model="${ref%%:*}"
        tag="${ref#*:}"
    else
        model="$ref"
        tag="latest"
    fi
    echo "$library" "$model" "$tag"
}

model_gguf_name() {
    # Get the local GGUF filename for a model ref
    local ref="$1"
    local manifest_file="$MANIFEST_DIR/${ref//[:\/]/_}.json"
    if [[ -f "$manifest_file" ]]; then
        python3 -c "import json; print(json.load(open('$manifest_file'))['gguf_file'])" 2>/dev/null
        return
    fi
    return 1
}

resolve_model() {
    local name="$1"
    # check manifest cache first
    local gguf
    gguf=$(model_gguf_name "$name" 2>/dev/null) && [[ -f "$MODELS_DIR/$gguf" ]] && echo "$gguf" && return

    # direct .gguf filename
    if [[ "$name" == *.gguf && -f "$MODELS_DIR/$name" ]]; then
        echo "$name"
        return
    fi
    # scan all manifests for partial match
    if [[ -d "$MANIFEST_DIR" ]]; then
        for mf in "$MANIFEST_DIR"/*.json; do
            [[ -f "$mf" ]] || continue
            local mref mfile
            mref=$(python3 -c "import json; print(json.load(open('$mf'))['model_ref'])" 2>/dev/null)
            mfile=$(python3 -c "import json; print(json.load(open('$mf'))['gguf_file'])" 2>/dev/null)
            if [[ "$mref" == *"$name"* && -f "$MODELS_DIR/$mfile" ]]; then
                echo "$mfile"
                return
            fi
        done
    fi
    # fallback: first .gguf in models dir matching name
    for f in "$MODELS_DIR"/*"$name"*.gguf; do
        [[ -f "$f" ]] && echo "$(basename "$f")" && return
    done
    return 1
}

find_mmproj() {
    # Find mmproj file for a given model GGUF filename
    local model_file="$1"
    local base="${model_file%.gguf}"
    # strip quant suffix (e.g. -Q4_K_M, -Q8_0, -bf16, -f16) to get model identity
    local identity
    identity=$(echo "$base" | sed -E 's/-([Qq][0-9]_[A-Za-z_0-9]+|[BbFf][0-9]+|[Ff]16|[Ff]32|[Bb][Ff]16)$//')
    # try: mmproj-<identity>*.gguf, then mmproj-<base>*.gguf
    for pattern in "mmproj-${identity}"*.gguf "mmproj-${base}"*.gguf "${base}"*mmproj*.gguf; do
        for f in "$MODELS_DIR"/$pattern; do
            [[ -f "$f" ]] && echo "$(basename "$f")" && return 0
        done
    done
    return 1
}

get_running_pid() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        cat "$PID_FILE"
        return 0
    fi
    return 1
}

# --- commands ---

cmd_serve() {
    local model_name="${1:-}"
    local model_file=""

    if [[ -n "$model_name" ]]; then
        model_file=$(resolve_model "$model_name") || { red "Unknown model: $model_name"; cmd_list; exit 1; }
    else
        # find first available model
        for key in "${!MODEL_FILES[@]}"; do
            if [[ -f "$MODELS_DIR/${MODEL_FILES[$key]}" ]]; then
                model_file="${MODEL_FILES[$key]}"
                model_name="$key"
                break
            fi
        done
        # fallback: any .gguf in models dir
        if [[ -z "$model_file" ]]; then
            model_file=$(ls "$MODELS_DIR"/*.gguf 2>/dev/null | head -1)
            if [[ -z "$model_file" ]]; then
                red "No models found. Run: ollama-rdna1 pull qwen2.5:1.5b"
                exit 1
            fi
            model_file=$(basename "$model_file")
        fi
    fi

    local model_path="$MODELS_DIR/$model_file"
    if [[ ! -f "$model_path" ]]; then
        red "Model file not found: $model_path"
        echo "Run: ollama-rdna1 pull $model_name"
        exit 1
    fi

    if pid=$(get_running_pid); then
        local current_model
        current_model=$(ps -p "$pid" -o args= 2>/dev/null | grep -oP '(?<=-m )\S+' | xargs basename 2>/dev/null || echo "")
        if [[ "$current_model" == "$model_file" ]]; then
            green "Already serving $model_file (PID $pid)"
            exit 0
        fi
        yellow "Switching model: $current_model -> $model_file"
        cmd_stop
    fi

    local mmproj_file
    mmproj_file=$(find_mmproj "$model_file") || true

    green "Starting ollama-rdna1 on port $PORT with $model_file"
    [[ -n "$mmproj_file" ]] && echo "Multimodal projector: $mmproj_file"
    echo "GPU layers: $GPU_LAYERS | Vulkan backend"
    echo "Ollama API: http://127.0.0.1:$PORT"
    echo "llama.cpp backend: http://127.0.0.1:$BACKEND_PORT"
    echo ""
    echo "Endpoints:"
    echo "  POST /api/chat       - chat completions (Ollama format)"
    echo "  POST /api/generate   - text completions (Ollama format)"
    echo "  GET  /api/tags       - list models"
    echo "  POST /api/show       - model info"
    echo "  POST /v1/chat/completions - OpenAI compatible (passthrough)"
    echo ""

    # start llama-server on backend port
    local server_args=(
        -m "$model_path"
        --port "$BACKEND_PORT"
        --gpu-layers "$GPU_LAYERS"
        --ctx-size 4096
        --host 127.0.0.1
    )
    if [[ -n "$mmproj_file" ]]; then
        server_args+=(--mmproj "$MODELS_DIR/$mmproj_file" --jinja)
    fi

    "$LLAMA_SERVER" "${server_args[@]}" >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"

    # wait for backend to be ready
    echo -n "Waiting for backend..."
    for i in {1..30}; do
        if curl -sf "http://127.0.0.1:$BACKEND_PORT/health" > /dev/null 2>&1; then
            echo " ready"
            break
        fi
        echo -n "."
        sleep 1
    done

    # start Ollama API proxy on public port
    python3 "$OLLAMA_PROXY" "$PORT" "$BACKEND_PORT" >> "$LOG_FILE" 2>&1 &
    echo $! > "$PROXY_PID_FILE"

    green "Server started. Backend PID $(cat "$PID_FILE"), Proxy PID $(cat "$PROXY_PID_FILE")"
    green "Logs: $LOG_FILE"
}

cmd_run() {
    local model_name="${1:-}"
    if [[ -z "$model_name" ]]; then
        red "Usage: ollama-rdna1 run <model>"
        cmd_list
        exit 1
    fi

    local model_file
    model_file=$(resolve_model "$model_name") || { red "Unknown model: $model_name"; cmd_list; exit 1; }
    local model_path="$MODELS_DIR/$model_file"

    if [[ ! -f "$model_path" ]]; then
        yellow "Model not downloaded. Pulling..."
        cmd_pull "$model_name"
    fi

    local mmproj_file
    mmproj_file=$(find_mmproj "$model_file") || true

    if [[ -n "$mmproj_file" ]]; then
        green "Running $model_file + $mmproj_file (multimodal chat, Ctrl+C to exit)"
        "$LLAMA_MTMD_CLI" \
            -m "$model_path" \
            --mmproj "$MODELS_DIR/$mmproj_file" \
            --gpu-layers "$GPU_LAYERS" \
            --ctx-size 4096 \
            --jinja
    else
        green "Running $model_file (interactive chat, Ctrl+C to exit)"
        "$LLAMA_CLI" \
            -m "$model_path" \
            --gpu-layers "$GPU_LAYERS" \
            --ctx-size 4096 \
            --conversation
    fi
}

cmd_list() {
    echo "Downloaded models:"
    printf "  %-25s %-40s %-6s %s\n" "NAME" "FILE" "SIZE" ""
    printf "  %-25s %-40s %-6s %s\n" "----" "----" "----" ""

    local found=0

    # list models from manifest cache
    if [[ -d "$MANIFEST_DIR" ]]; then
        for mf in "$MANIFEST_DIR"/*.json; do
            [[ -f "$mf" ]] || continue
            local mref mfile
            mref=$(python3 -c "import json; print(json.load(open('$mf'))['model_ref'])" 2>/dev/null) || continue
            mfile=$(python3 -c "import json; print(json.load(open('$mf'))['gguf_file'])" 2>/dev/null) || continue
            if [[ -f "$MODELS_DIR/$mfile" ]]; then
                local size mmtag=""
                size=$(du -h "$MODELS_DIR/$mfile" | cut -f1)
                find_mmproj "$mfile" > /dev/null 2>&1 && mmtag="[multimodal]"
                printf "  %-25s %-40s %-6s %s\n" "$mref" "$mfile" "$size" "$mmtag"
                found=1
            fi
        done
    fi

    # list any .gguf not tracked by manifests
    for f in "$MODELS_DIR"/*.gguf; do
        [[ -f "$f" ]] || continue
        local base
        base=$(basename "$f")
        # check if already listed via manifest
        local tracked=0
        if [[ -d "$MANIFEST_DIR" ]]; then
            for mf in "$MANIFEST_DIR"/*.json; do
                [[ -f "$mf" ]] || continue
                local mfile
                mfile=$(python3 -c "import json; print(json.load(open('$mf'))['gguf_file'])" 2>/dev/null) || continue
                [[ "$mfile" == "$base" ]] && tracked=1 && break
            done
        fi
        if [[ $tracked -eq 0 ]]; then
            # skip mmproj files — they're accessories, not standalone models
            [[ "$base" == mmproj-* ]] && continue
            local size mmtag=""
            size=$(du -h "$f" | cut -f1)
            find_mmproj "$base" > /dev/null 2>&1 && mmtag="[multimodal]"
            printf "  %-25s %-40s %-6s %s\n" "(untracked)" "$base" "$size" "$mmtag"
            found=1
        fi
    done

    if [[ $found -eq 0 ]]; then
        echo "  (none)"
        echo ""
        echo "Pull a model: ollama-rdna1 pull qwen2.5:1.5b"
    fi
}

cmd_pull() {
    local model_name="${1:-}"
    if [[ -z "$model_name" ]]; then
        red "Usage: ollama-rdna1 pull <model>"
        echo "Examples: ollama-rdna1 pull qwen2.5:1.5b"
        echo "          ollama-rdna1 pull llama3.2"
        echo "          ollama-rdna1 pull mistral:7b"
        echo "          ollama-rdna1 pull hf:ggml-org/gemma-4-E4B-it-GGUF:Q4_K_M"
        echo "          ollama-rdna1 pull https://example.com/model.gguf"
        exit 1
    fi

    # HuggingFace repo pull: hf:user/repo[:quant]
    if [[ "$model_name" == hf:* ]]; then
        local hf_ref="${model_name#hf:}"
        local hf_repo hf_quant
        if [[ "$hf_ref" == *:* ]]; then
            hf_repo="${hf_ref%:*}"
            hf_quant="${hf_ref##*:}"
        else
            hf_repo="$hf_ref"
            hf_quant="Q4_K_M"
        fi
        local repo_name="${hf_repo##*/}"
        local base_name="${repo_name%-GGUF}"

        green "Pulling from HuggingFace: $hf_repo (quant: $hf_quant)"
        local hf_base="https://huggingface.co/$hf_repo/resolve/main"

        # download main model
        local model_filename="${base_name}-${hf_quant}.gguf"
        if [[ -f "$MODELS_DIR/$model_filename" ]]; then
            green "Model already exists: $model_filename ($(du -h "$MODELS_DIR/$model_filename" | cut -f1))"
        else
            echo "Downloading $model_filename..."
            curl -L --progress-bar -o "$MODELS_DIR/$model_filename" "$hf_base/$model_filename" || {
                red "Failed to download $model_filename"
                exit 1
            }
            green "Downloaded: $model_filename ($(du -h "$MODELS_DIR/$model_filename" | cut -f1))"
        fi

        # try to download mmproj if it exists
        local mmproj_filename="mmproj-${base_name}-Q8_0.gguf"
        if [[ -f "$MODELS_DIR/$mmproj_filename" ]]; then
            green "mmproj already exists: $mmproj_filename"
        else
            echo "Checking for multimodal projector..."
            if curl -sfI "$hf_base/$mmproj_filename" > /dev/null 2>&1; then
                echo "Downloading $mmproj_filename..."
                curl -L --progress-bar -o "$MODELS_DIR/$mmproj_filename" "$hf_base/$mmproj_filename"
                green "Downloaded: $mmproj_filename ($(du -h "$MODELS_DIR/$mmproj_filename" | cut -f1))"
            else
                echo "No mmproj found (text-only model)"
            fi
        fi

        # save manifest
        mkdir -p "$MANIFEST_DIR"
        local short_name="${base_name,,}"
        short_name="${short_name//-/:}"
        local manifest_file="$MANIFEST_DIR/${short_name//[:\/]/_}.json"
        python3 -c "
import json
info = {
    'model_ref': '$short_name',
    'gguf_file': '$model_filename',
    'digest': 'hf:$hf_repo',
    'size': $(stat --printf="%s" "$MODELS_DIR/$model_filename" 2>/dev/null || echo 0),
    'source': 'huggingface',
    'hf_repo': '$hf_repo'
}
json.dump(info, open('$manifest_file', 'w'), indent=2)
"
        green "Done: $short_name"
        return
    fi

    # direct URL download
    if [[ "$model_name" == http* ]]; then
        local filename
        filename=$(basename "$model_name")
        green "Downloading $filename..."
        curl -L --progress-bar -o "$MODELS_DIR/$filename" "$model_name"
        green "Done: $MODELS_DIR/$filename"
        return
    fi

    # check if already pulled
    local existing
    existing=$(model_gguf_name "$model_name" 2>/dev/null) || true
    if [[ -n "$existing" && -f "$MODELS_DIR/$existing" ]]; then
        green "$model_name already downloaded ($existing, $(du -h "$MODELS_DIR/$existing" | cut -f1))"
        return
    fi

    # parse model reference
    read -r library model tag <<< "$(parse_model_ref "$model_name")"
    local ref="${model}:${tag}"

    green "Pulling $ref from Ollama registry..."

    # 1. fetch manifest
    local manifest_url="$OLLAMA_REGISTRY/v2/$library/$model/manifests/$tag"
    echo "Fetching manifest: $manifest_url"
    local manifest
    manifest=$(curl -sf "$manifest_url") || { red "Model not found: $ref"; exit 1; }

    # 2. find the model layer (GGUF blob)
    local blob_digest blob_size
    blob_digest=$(echo "$manifest" | python3 -c "
import json, sys
m = json.load(sys.stdin)
for layer in m['layers']:
    if layer['mediaType'] == 'application/vnd.ollama.image.model':
        print(layer['digest'])
        break
")
    blob_size=$(echo "$manifest" | python3 -c "
import json, sys
m = json.load(sys.stdin)
for layer in m['layers']:
    if layer['mediaType'] == 'application/vnd.ollama.image.model':
        print(layer['size'])
        break
")

    if [[ -z "$blob_digest" ]]; then
        red "No model layer found in manifest"
        exit 1
    fi

    local size_mb=$((blob_size / 1024 / 1024))
    local gguf_file="${model}-${tag}.gguf"

    echo "Model: $ref"
    echo "Size: ${size_mb}MB"
    echo "Digest: ${blob_digest:0:19}..."
    echo "Saving to: $MODELS_DIR/$gguf_file"
    echo ""

    # 3. download the blob
    local blob_url="$OLLAMA_REGISTRY/v2/$library/$model/blobs/$blob_digest"
    curl -L --progress-bar -o "$MODELS_DIR/$gguf_file" "$blob_url"

    # 4. verify size
    local actual_size
    actual_size=$(stat --printf="%s" "$MODELS_DIR/$gguf_file" 2>/dev/null || stat -f%z "$MODELS_DIR/$gguf_file" 2>/dev/null)
    if [[ "$actual_size" -ne "$blob_size" ]]; then
        red "Size mismatch! Expected $blob_size, got $actual_size"
        rm -f "$MODELS_DIR/$gguf_file"
        exit 1
    fi

    # 5. save manifest for local tracking
    mkdir -p "$MANIFEST_DIR"
    local manifest_file="$MANIFEST_DIR/${ref//[:\/]/_}.json"
    echo "$manifest" | python3 -c "
import json, sys
m = json.load(sys.stdin)
info = {
    'model_ref': '$ref',
    'gguf_file': '$gguf_file',
    'digest': '$blob_digest',
    'size': $blob_size,
    'layers': len(m['layers'])
}
json.dump(info, open('$manifest_file', 'w'), indent=2)
"

    green "Done: $ref -> $gguf_file ($(du -h "$MODELS_DIR/$gguf_file" | cut -f1))"
}

cmd_stop() {
    local stopped=0
    if [[ -f "$PROXY_PID_FILE" ]] && kill -0 "$(cat "$PROXY_PID_FILE")" 2>/dev/null; then
        kill "$(cat "$PROXY_PID_FILE")" 2>/dev/null
        rm -f "$PROXY_PID_FILE"
        stopped=1
    fi
    if pid=$(get_running_pid); then
        kill "$pid" 2>/dev/null
        rm -f "$PID_FILE"
        stopped=1
    fi
    if [[ $stopped -eq 1 ]]; then
        green "Server stopped"
    else
        yellow "No server running"
    fi
}

cmd_ps() {
    if pid=$(get_running_pid); then
        green "Server running"
        echo "  Backend PID: $pid (port $BACKEND_PORT)"
        if [[ -f "$PROXY_PID_FILE" ]] && kill -0 "$(cat "$PROXY_PID_FILE")" 2>/dev/null; then
            echo "  Proxy PID:   $(cat "$PROXY_PID_FILE") (port $PORT)"
        fi
        echo "  Log: $LOG_FILE"
        echo -n "  Model: "
        ps -p "$pid" -o args= 2>/dev/null | grep -oP '(?<=-m )\S+' | xargs basename 2>/dev/null || echo "unknown"
    else
        yellow "No server running"
    fi
}

# --- main ---

mkdir -p "$MODELS_DIR"

case "${1:-help}" in
    serve)  shift; cmd_serve "$@" ;;
    run)    shift; cmd_run "$@" ;;
    list)   cmd_list ;;
    pull)   shift; cmd_pull "$@" ;;
    stop)   cmd_stop ;;
    ps)     cmd_ps ;;
    help|--help|-h)
        echo "ollama-rdna1 - llama.cpp Vulkan wrapper (Ollama-compatible API)"
        echo ""
        echo "Usage: ollama-rdna1 <command> [args]"
        echo ""
        echo "Commands:"
        echo "  serve [model]   Start API server on port $PORT (default: first available model)"
        echo "  run <model>     Interactive chat with model"
        echo "  list            List available models"
        echo "  pull <model>    Download a model"
        echo "  stop            Stop the server"
        echo "  ps              Show server status"
        echo ""
        echo "Models are stored in: $MODELS_DIR"
        echo "Backend: llama.cpp + Vulkan (AMD RX 5700)"
        ;;
    *)
        red "Unknown command: $1"
        echo "Run: ollama-rdna1 help"
        exit 1
        ;;
esac
